# BuildWise Environment Configuration
# Copy this file to .env and fill in your own secret values.

# Database Configuration (Railway PostgreSQL)
DB_HOST=your_railway_db_host
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your_railway_db_password

# AI / Backend Keys
GROQ_API_KEY=your_groq_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key
SECRET_KEY=your_jwt_secret_key_min_32_chars

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-railway-backend.railway.app/auth/google/callback

# Razorpay Configuration (use production keys in production)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMTP Email Configuration (Gmail or SendGrid)
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_or_sendgrid_key
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Application URLs
# For local development
FRONTEND_URL_DEV=http://localhost:5173
BACKEND_URL_DEV=http://localhost:8000

# For production (Railway & Vercel)
FRONTEND_URL=https://your-vercel-deployment.vercel.app
BACKEND_URL=https://your-railway-backend.railway.app

# For current environment (set by deployment platform)
FRONTEND_URL=${FRONTEND_URL}
BACKEND_URL=${BACKEND_URL}
